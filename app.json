{
  "expo": {
    "name": "Fruity Splash",
    "slug": "fruity-splash",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "fruitysplash",
    "plugins": [
      "expo-router",
      [
        "expo-status-bar",
        {
          "hidden": true,
          "style": "dark"
        }
      ],
      [
        "expo-navigation-bar",
        {
          "hidden": true,
          "style": "dark",
          "enforceContrast": false
        }
      ],
      "expo-image",
      "@react-native-google-signin/google-signin",
      "expo-iap"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hieplex.fruitysplash"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "expo-status-bar": {
        "style": "dark",
        "hidden": true
      },
      "expo-navigation-bar": {
        "enforceContrast": false,
        "style": "dark",
        "hidden": true
      },
      "eas": {
        "projectId": "bc52c68d-5ea3-4150-9539-124930870273"
      }
    }
  }
}
